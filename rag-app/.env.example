# ── Required ──────────────────────────────────────────
# Get a free key at: https://console.groq.com
GROQ_API_KEY=your_groq_key_here

# ── Optional (paper-recommended defaults) ─────────────
LLM_MODEL=llama-3.3-70b-versatile

TOP_K=10          # how many chunks to fetch from hybrid search
TOP_N=5           # how many to keep after reranking
ALPHA=0.3         # BM25 weight in hybrid score (paper §3.4.3 optimal)

CHUNK_SIZE=512    # target tokens per chunk  (paper §3.2.1)
CHUNK_OVERLAP=20  # overlap tokens between chunks

CHROMA_PERSIST_DIR=./chroma_db    # ChromaDB saves here (auto-created)
